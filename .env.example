# InternWealth environment config. Copy to `.env` for local dev, or set these in
# your Vercel project's Environment Variables. NEVER commit a real .env.

# --- LLM backend (pick ONE) ---------------------------------------------------
# Option A (public deploy / Vercel): Anthropic direct key. When this is set, the
# app calls the Anthropic API directly. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional: override the Anthropic model id (default: claude-sonnet-5).
# ANTHROPIC_MODEL_ID=claude-sonnet-5

# Option B (local dev): leave ANTHROPIC_API_KEY unset to fall back to Amazon
# Bedrock using your machine's AWS credential chain (env vars, ~/.aws, SSO, role).
# AWS_REGION=us-east-1
# Optional: override the Bedrock model id / inference profile.
# BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-5

# --- Plaid (bank linking) -----------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
